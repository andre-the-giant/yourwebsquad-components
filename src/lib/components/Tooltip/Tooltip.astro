---
import { validateProps } from "../../utils/props.js";
import { makeStyleVars, mergeClasses } from "../../utils/style.js";

const schema = {
  id: { type: "string" },
  class: { type: "string" },
  style: { type: "string" },
  text: { type: "string" },
  position: { type: "string" },
  maxWidth: { type: "string" }
};

const {
  id,
  class: className,
  style,
  text,
  position = "top",
  maxWidth,
  ...rest
} = validateProps(schema, Astro.props, { component: "Tooltip" });

const allowedPositions = new Set(["top", "right", "bottom", "left"]);
const resolvedPosition = allowedPositions.has(position) ? position : "top";
const resolvedId = id ?? `tooltip-${Math.random().toString(36).slice(2, 9)}`;

const styleVars = {
  "--tooltip-max-width": maxWidth
};

const resolvedStyle = makeStyleVars(styleVars, style);
const resolvedClass = mergeClasses("tooltip", `tooltip--${resolvedPosition}`, className);
---

<span class={resolvedClass} style={resolvedStyle || undefined} data-tooltip-root {...rest}>
  <span class="tooltip__anchor" data-tooltip-anchor>
    <slot name="trigger" />
  </span>
  <span id={resolvedId} role="tooltip" class="tooltip__content" data-tooltip-content>
    <slot>{text}</slot>
  </span>
</span>

<script>
  const withId = (value) => String(value ?? "").trim();

  const setAriaDescribedBy = (owner, tooltipId) => {
    if (!owner || !tooltipId) return;

    const existing = withId(owner.getAttribute("aria-describedby"));
    if (!existing) {
      owner.setAttribute("aria-describedby", tooltipId);
      return;
    }

    const tokens = existing.split(/\s+/).filter(Boolean);
    if (!tokens.includes(tooltipId)) {
      owner.setAttribute("aria-describedby", `${existing} ${tooltipId}`.trim());
    }
  };

  const getOwner = (root) => {
    const anchor = root.querySelector("[data-tooltip-anchor]");
    if (!anchor) return null;

    const explicit = anchor.querySelector("[data-tooltip-owner]");
    if (explicit) return explicit;

    if (anchor.firstElementChild instanceof HTMLElement) return anchor.firstElementChild;

    return null;
  };

  document.querySelectorAll("[data-tooltip-root]").forEach((root) => {
    if (!(root instanceof HTMLElement)) return;
    if (root.dataset.tooltipReady === "true") return;

    root.dataset.tooltipReady = "true";

    const tooltip = root.querySelector("[data-tooltip-content]");
    if (!(tooltip instanceof HTMLElement)) return;

    const tooltipId = withId(tooltip.id);
    const owner = getOwner(root);

    if (owner) {
      setAriaDescribedBy(owner, tooltipId);
    }

    root.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      root.dataset.tooltipDismissed = "true";
    });

    const clearDismissed = () => {
      delete root.dataset.tooltipDismissed;
    };

    root.addEventListener("focusin", clearDismissed);
    root.addEventListener("mouseenter", clearDismissed);
  });
</script>

<style>
  .tooltip {
    display: inline-flex;
    position: relative;
    width: fit-content;
    max-width: 100%;
  }

  .tooltip__anchor {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
  }

  .tooltip__content {
    position: absolute;
    z-index: 50;
    max-width: min(var(--tooltip-max-width, 22rem), calc(100vw - 1.25rem));
    width: max-content;
    padding: 0.4rem 0.55rem;
    border-radius: 0.375rem;
    border: 1px solid rgb(255 255 255 / 0.2);
    background: #111;
    color: #fff;
    font-size: 0.875rem;
    line-height: 1.35;
    box-shadow: 0 10px 30px -16px rgb(0 0 0 / 0.7);
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.16s ease, visibility 0.16s ease;
  }

  .tooltip__content::after {
    content: "";
    position: absolute;
    border-width: 0.35rem;
    border-style: solid;
  }

  .tooltip--top .tooltip__content {
    left: 50%;
    bottom: calc(100% + 0.45rem);
    transform: translateX(-50%);
  }

  .tooltip--top .tooltip__content::after {
    left: 50%;
    top: 100%;
    transform: translateX(-50%);
    border-color: #111 transparent transparent transparent;
  }

  .tooltip--right .tooltip__content {
    left: calc(100% + 0.45rem);
    top: 50%;
    transform: translateY(-50%);
  }

  .tooltip--right .tooltip__content::after {
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    border-color: transparent #111 transparent transparent;
  }

  .tooltip--bottom .tooltip__content {
    left: 50%;
    top: calc(100% + 0.45rem);
    transform: translateX(-50%);
  }

  .tooltip--bottom .tooltip__content::after {
    left: 50%;
    bottom: 100%;
    transform: translateX(-50%);
    border-color: transparent transparent #111 transparent;
  }

  .tooltip--left .tooltip__content {
    right: calc(100% + 0.45rem);
    top: 50%;
    transform: translateY(-50%);
  }

  .tooltip--left .tooltip__content::after {
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    border-color: transparent transparent transparent #111;
  }

  .tooltip:hover .tooltip__content,
  .tooltip:focus-within .tooltip__content,
  .tooltip__content:hover {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition-delay: 0s;
  }

  .tooltip[data-tooltip-dismissed="true"] .tooltip__content {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .tooltip__content {
      transition: none;
    }
  }
</style>
